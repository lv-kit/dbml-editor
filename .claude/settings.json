{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-no-verify.sh" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-force-push.sh" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit-ci.sh" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/require-plan-for-large-task.sh" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/detect-secrets.sh" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/config-protection.sh" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/warn-console-log.sh" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/warn-scope-creep.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-file-size.sh" }
        ]
      }
    ],
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start-context.sh" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-compact-save.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-stop-summary.sh" } ] }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm run check)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run format)",
      "Bash(pnpm run test:unit:*)",
      "Bash(pnpm run test)",
      "Bash(pnpm exec prettier:*)",
      "Bash(pnpm exec eslint:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)"
    ],
    "deny": [
      "Bash(wrangler deploy:*)",
      "Bash(pnpm exec wrangler deploy:*)",
      "Bash(drizzle-kit push:*)",
      "Bash(drizzle-kit migrate:*)",
      "Bash(pnpm run db:push:*)",
      "Bash(pnpm run db:migrate:*)",
      "Bash(rm -rf:*)",
      "Read(./web/.env)",
      "Read(./web/.env.*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "env": {
    "MAX_THINKING_TOKENS": "10000"
  }
}
