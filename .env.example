# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Auth.js
AUTH_SECRET="your-random-secret-here"
AUTH_TRUST_HOST="true"

# Google OAuth (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Microsoft Entra ID OAuth (optional)
MICROSOFT_ENTRA_ID_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_ENTRA_ID_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_ENTRA_ID_TENANT="common"

# Resend Email (optional - for email link authentication)
RESEND_API_KEY="your-resend-api-key"
