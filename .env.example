# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Session signing secret (required)
AUTH_SECRET="your-random-secret-here"

# Firebase project configuration (required)
FIREBASE_API_KEY="your-firebase-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_APP_ID="your-firebase-app-id"

# Firebase Auth providers (optional - set to "false" to disable)
# Google Sign-In is enabled by default when FIREBASE_API_KEY is set
FIREBASE_GOOGLE_ENABLED="true"
# Microsoft Sign-In requires explicit opt-in
FIREBASE_MICROSOFT_ENABLED="false"
# Email link Sign-In is enabled by default when FIREBASE_API_KEY is set
FIREBASE_EMAIL_ENABLED="true"
